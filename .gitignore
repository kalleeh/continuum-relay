# Cross-compiled release binaries — built by `make release`, published via
# GitHub Actions, never committed to source.
continuum-relay-linux-amd64
continuum-relay-linux-arm64
continuum-relay-darwin-amd64
continuum-relay-darwin-arm64
checksums.txt

# Stale build/dist directories that older flows produced.
/dist/

# Generated by deploy.sh runs — SSH keys, WireGuard secrets, env files
# end up in the working dir when developers test the script locally.
dev-box-*
*.key
*.pub
*.conf
.env
.env.*
