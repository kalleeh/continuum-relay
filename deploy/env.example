# /etc/continuum/env
# Generated by deploy.sh --mobile-app
# chmod 600, chown ubuntu:ubuntu

CONTINUUM_TOKEN=replace_with_64_hex_chars
CONTINUUM_RELAY_ADDR=10.100.0.1:7682
CONTINUUM_RELAY_LOG=/var/log/continuum/relay.log

# WireGuard — path to wg0.conf (created by deploy.sh, read by continuum-relay)
CONTINUUM_WG_CONFIG=/etc/wireguard/wg0.conf
# Set to 1 to skip embedded WireGuard (if managed externally, or during dev)
#CONTINUUM_WG_DISABLED=1

# Terminal server — replaces ttyd
CONTINUUM_TERMINAL_ADDR=10.100.0.1:7681
# Command run in each PTY session (default: tmux new-session -A -s main)
#CONTINUUM_TERMINAL_CMD=tmux new-session -A -s main

# Optional: APNs push notifications (SESSION_FINISHED alerts to iOS app)
# Obtain from Apple Developer Portal → Certificates, Identifiers & Profiles → Keys
# Leave unset to run without push notifications.
#APNS_KEY_PATH=/etc/continuum/AuthKey_XXXXXXXXXX.p8
#APNS_KEY_ID=XXXXXXXXXX
#APNS_TEAM_ID=XXXXXXXXXX
#APNS_BUNDLE_ID=com.continuum.app
